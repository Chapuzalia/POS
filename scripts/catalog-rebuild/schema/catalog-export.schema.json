{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clubpos.local/schemas/catalog-export-v2.json",
  "title": "Club POS catalog export",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "schemaVersion", "metadata", "catalog"],
  "properties": {
    "format": { "const": "club-pos-catalog-export" },
    "schemaVersion": { "const": 2 },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["exportedAt", "origin", "fiscal", "counts"],
      "properties": {
        "exportedAt": { "type": "string", "format": "date-time" },
        "origin": { "type": "object" },
        "fiscal": {
          "type": "object",
          "required": ["defaultTaxRate", "currencyCode", "timezone"],
          "properties": {
            "defaultTaxRate": { "type": "number", "minimum": 0, "maximum": 100, "multipleOf": 0.01 },
            "currencyCode": { "type": "string", "pattern": "^[A-Z]{3}$" },
            "timezone": { "type": "string", "minLength": 1 }
          }
        },
        "counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "trace": { "$ref": "#/$defs/openBlock" },
        "source": { "$ref": "#/$defs/openBlock" }
      }
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["categories", "saleFormats", "tabs", "tabCategories", "products", "variants", "placements", "selectionGroups", "selectionGroupOptions", "selectionAssignments", "modifierGroups", "modifiers", "modifierAssignments", "images"],
      "properties": {
        "categories": { "type": "array", "items": { "$ref": "#/$defs/category" } },
        "saleFormats": { "type": "array", "items": { "$ref": "#/$defs/saleFormat" } },
        "tabs": { "type": "array", "items": { "$ref": "#/$defs/tab" } },
        "tabCategories": { "type": "array", "items": { "$ref": "#/$defs/tabCategory" } },
        "products": { "type": "array", "items": { "$ref": "#/$defs/product" } },
        "variants": { "type": "array", "items": { "$ref": "#/$defs/variant" } },
        "placements": { "type": "array", "items": { "$ref": "#/$defs/placement" } },
        "selectionGroups": { "type": "array", "items": { "$ref": "#/$defs/selectionGroup" } },
        "selectionGroupOptions": { "type": "array", "items": { "$ref": "#/$defs/selectionOption" } },
        "selectionAssignments": { "type": "array", "items": { "$ref": "#/$defs/assignment" } },
        "modifierGroups": { "type": "array", "items": { "$ref": "#/$defs/modifierGroup" } },
        "modifiers": { "type": "array", "items": { "$ref": "#/$defs/modifier" } },
        "modifierAssignments": { "type": "array", "items": { "$ref": "#/$defs/assignment" } },
        "images": { "type": "array", "items": { "$ref": "#/$defs/image" } }
      }
    }
  },
  "$defs": {
    "ref": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "nullableRef": { "oneOf": [{ "$ref": "#/$defs/ref" }, { "type": "null" }] },
    "nullableString": { "type": ["string", "null"] },
    "money": { "type": "integer", "minimum": -100000000, "maximum": 100000000 },
    "sortOrder": { "type": "integer", "minimum": 0 },
    "openBlock": { "type": "object", "additionalProperties": true },
    "category": {
      "type": "object", "additionalProperties": false,
      "required": ["ref", "name", "icon", "sortOrder", "isActive", "unused", "trace", "source"],
      "properties": {
        "ref": { "$ref": "#/$defs/ref" }, "name": { "type": "string", "minLength": 1 }, "icon": { "$ref": "#/$defs/nullableString" },
        "sortOrder": { "$ref": "#/$defs/sortOrder" }, "isActive": { "type": "boolean" }, "unused": { "type": "boolean" },
        "trace": { "$ref": "#/$defs/openBlock" }, "source": { "$ref": "#/$defs/openBlock" }
      }
    },
    "saleFormat": {
      "type": "object", "additionalProperties": false,
      "required": ["ref", "key", "label", "sortOrder", "isActive", "trace", "source"],
      "properties": {
        "ref": { "$ref": "#/$defs/ref" }, "key": { "type": "string", "minLength": 1 }, "label": { "type": "string", "minLength": 1 },
        "sortOrder": { "$ref": "#/$defs/sortOrder" }, "isActive": { "type": "boolean" }, "trace": { "$ref": "#/$defs/openBlock" }, "source": { "$ref": "#/$defs/openBlock" }
      }
    },
    "tab": {
      "type": "object", "additionalProperties": false,
      "required": ["ref", "key", "label", "icon", "sortOrder", "isActive", "trace"],
      "properties": {
        "ref": { "$ref": "#/$defs/ref" }, "key": { "type": "string", "minLength": 1 }, "label": { "type": "string", "minLength": 1 },
        "icon": { "$ref": "#/$defs/nullableString" }, "sortOrder": { "$ref": "#/$defs/sortOrder" }, "isActive": { "type": "boolean" }, "trace": { "$ref": "#/$defs/openBlock" }
      }
    },
    "tabCategory": {
      "type": "object", "additionalProperties": false,
      "required": ["ref", "tabRef", "categoryRef", "sortOrder", "isActive", "source"],
      "properties": {
        "ref": { "$ref": "#/$defs/ref" }, "tabRef": { "$ref": "#/$defs/ref" }, "categoryRef": { "$ref": "#/$defs/ref" },
        "sortOrder": { "$ref": "#/$defs/sortOrder" }, "isActive": { "type": "boolean" }, "source": { "$ref": "#/$defs/openBlock" }
      }
    },
    "product": {
      "type": "object", "additionalProperties": false,
      "required": ["ref", "type", "name", "description", "imageRef", "taxRate", "sortOrder", "isActive", "trace", "source"],
      "properties": {
        "ref": { "$ref": "#/$defs/ref" }, "type": { "enum": ["standard", "menu"] }, "name": { "type": "string", "minLength": 1 },
        "description": { "$ref": "#/$defs/nullableString" }, "imageRef": { "$ref": "#/$defs/nullableRef" },
        "taxRate": { "oneOf": [{ "type": "number", "minimum": 0, "maximum": 100, "multipleOf": 0.01 }, { "type": "null" }] },
        "sortOrder": { "$ref": "#/$defs/sortOrder" }, "isActive": { "type": "boolean" }, "trace": { "$ref": "#/$defs/openBlock" }, "source": { "$ref": "#/$defs/openBlock" }
      }
    },
    "variant": {
      "type": "object", "additionalProperties": false,
      "required": ["ref", "productRef", "name", "priceCents", "sku", "isDefault", "sortOrder", "isActive", "trace", "source"],
      "properties": {
        "ref": { "$ref": "#/$defs/ref" }, "productRef": { "$ref": "#/$defs/ref" }, "name": { "type": "string", "minLength": 1 },
        "priceCents": { "type": "integer", "minimum": 0, "maximum": 100000000 }, "sku": { "$ref": "#/$defs/nullableString" },
        "isDefault": { "type": "boolean" }, "sortOrder": { "$ref": "#/$defs/sortOrder" }, "isActive": { "type": "boolean" },
        "trace": { "$ref": "#/$defs/openBlock" }, "source": { "$ref": "#/$defs/openBlock" }
      }
    },
    "placement": {
      "type": "object", "additionalProperties": false,
      "required": ["ref", "productRef", "tabRef", "categoryRef", "variantRef", "featured", "sortOrder", "isActive", "trace"],
      "properties": {
        "ref": { "$ref": "#/$defs/ref" }, "productRef": { "$ref": "#/$defs/ref" }, "tabRef": { "$ref": "#/$defs/ref" },
        "categoryRef": { "$ref": "#/$defs/nullableRef" }, "variantRef": { "$ref": "#/$defs/nullableRef" }, "featured": { "type": "boolean" },
        "sortOrder": { "$ref": "#/$defs/sortOrder" }, "isActive": { "type": "boolean" }, "trace": { "$ref": "#/$defs/openBlock" }
      }
    },
    "selectionGroup": {
      "type": "object", "additionalProperties": false,
      "required": ["ref", "name", "type", "sortOrder", "isActive", "trace", "source"],
      "properties": {
        "ref": { "$ref": "#/$defs/ref" }, "name": { "type": "string", "minLength": 1 }, "type": { "enum": ["mixer", "menu_component"] },
        "sortOrder": { "$ref": "#/$defs/sortOrder" }, "isActive": { "type": "boolean" }, "trace": { "$ref": "#/$defs/openBlock" }, "source": { "$ref": "#/$defs/openBlock" }
      }
    },
    "selectionOption": {
      "type": "object", "additionalProperties": false,
      "required": ["ref", "groupRef", "productRef", "variantRef", "supplementCents", "defaultQuantity", "maxQuantity", "sortOrder", "isActive", "trace"],
      "properties": {
        "ref": { "$ref": "#/$defs/ref" }, "groupRef": { "$ref": "#/$defs/ref" }, "productRef": { "$ref": "#/$defs/ref" },
        "variantRef": { "$ref": "#/$defs/nullableRef" }, "supplementCents": { "$ref": "#/$defs/money" },
        "defaultQuantity": { "type": "integer", "minimum": 0 }, "maxQuantity": { "type": ["integer", "null"], "minimum": 0 },
        "sortOrder": { "$ref": "#/$defs/sortOrder" }, "isActive": { "type": "boolean" }, "trace": { "$ref": "#/$defs/openBlock" }
      }
    },
    "assignment": {
      "type": "object", "additionalProperties": false,
      "required": ["ref", "productRef", "groupRef", "variantRefs", "minSelection", "maxSelection", "sortOrder", "isActive", "displayName", "trace"],
      "properties": {
        "ref": { "$ref": "#/$defs/ref" }, "productRef": { "$ref": "#/$defs/ref" }, "groupRef": { "$ref": "#/$defs/ref" },
        "variantRefs": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/ref" } },
        "minSelection": { "type": "integer", "minimum": 0 }, "maxSelection": { "type": "integer", "minimum": 1 },
        "sortOrder": { "$ref": "#/$defs/sortOrder" }, "isActive": { "type": "boolean" }, "displayName": { "$ref": "#/$defs/nullableString" },
        "trace": { "$ref": "#/$defs/openBlock" }
      }
    },
    "modifierGroup": {
      "type": "object", "additionalProperties": false,
      "required": ["ref", "name", "sortOrder", "isActive", "trace", "source"],
      "properties": { "ref": { "$ref": "#/$defs/ref" }, "name": { "type": "string", "minLength": 1 }, "sortOrder": { "$ref": "#/$defs/sortOrder" }, "isActive": { "type": "boolean" }, "trace": { "$ref": "#/$defs/openBlock" }, "source": { "$ref": "#/$defs/openBlock" } }
    },
    "modifier": {
      "type": "object", "additionalProperties": false,
      "required": ["ref", "groupRef", "name", "supplementCents", "isDefault", "sortOrder", "isActive", "trace"],
      "properties": { "ref": { "$ref": "#/$defs/ref" }, "groupRef": { "$ref": "#/$defs/ref" }, "name": { "type": "string", "minLength": 1 }, "supplementCents": { "$ref": "#/$defs/money" }, "isDefault": { "type": "boolean" }, "sortOrder": { "$ref": "#/$defs/sortOrder" }, "isActive": { "type": "boolean" }, "trace": { "$ref": "#/$defs/openBlock" } }
    },
    "image": {
      "type": "object", "additionalProperties": false,
      "required": ["ref", "productRef", "file", "mimeType", "sizeBytes", "sha256", "missing", "trace", "source"],
      "properties": {
        "ref": { "$ref": "#/$defs/ref" }, "productRef": { "$ref": "#/$defs/ref" }, "file": { "type": ["string", "null"], "pattern": "^images/[a-z][a-z0-9_]*\\.[a-z0-9]+$" },
        "mimeType": { "type": ["string", "null"] }, "sizeBytes": { "type": ["integer", "null"], "minimum": 0 },
        "sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }, "missing": { "type": "boolean" },
        "trace": { "$ref": "#/$defs/openBlock" }, "source": { "$ref": "#/$defs/openBlock" }
      }
    }
  }
}
